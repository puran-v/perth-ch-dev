// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
  DRIVER
}

// Author: samir
// Impact: tracks whether Module A setup has been saved as draft or committed
// Reason: the org-setup UI needs to persist partial progress (draft) and a
// final validated state (complete) so the Save Draft / Save & Continue
// buttons can round-trip through the API without losing work
enum OrgSetupStatus {
  DRAFT
  COMPLETE
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users                 User[]
  emailVerificationOtps EmailVerificationOtp[]
  orgSetup              OrgSetup?

  @@map("organizations")
}

// Old Author: samir
// New Author: samir
// Impact: 1:1 companion table for Organization that holds Module A setup state
// Reason: business/warehouse/payment/branding sections are stored as JSON so drafts can
// hold partial/invalid data while the COMPLETE status guarantees the payload
// has passed the strict Zod schema on the server. Using JSON keeps drafts
// simple; the app layer is responsible for re-validating before use.
//
// `branding` was added in migration 20260406110000_add_org_setup_branding —
// it holds logo data URL (placeholder until real object storage), brand
// colours (primary + accent hex), and email sender identity (from name /
// from email / reply-to + DNS status stub).
model OrgSetup {
  id        String         @id @default(cuid())
  orgId     String         @unique
  status    OrgSetupStatus @default(DRAFT)
  business  Json?
  warehouse Json?
  payment   Json?
  branding  Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?

  org Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@map("org_setups")
}

model User {
  id           String    @id @default(cuid())
  orgId        String?
  fullName     String
  email        String    @unique
  passwordHash String?
  role         UserRole  @default(ADMIN)
  isVerified   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  org                   Organization?          @relation(fields: [orgId], references: [id])
  emailVerificationOtps EmailVerificationOtp[]
  sessions              Session[]
  passwordResetTokens   PasswordResetToken[]
  accounts              Account[]

  @@index([orgId])
  @@map("users")
}

model Account {
  id                String    @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  type              String    @default("oauth")
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model EmailVerificationOtp {
  id         String    @id @default(cuid())
  orgId      String?
  userId     String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  org  Organization? @relation(fields: [orgId], references: [id])
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_otps")
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}
