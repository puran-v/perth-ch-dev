# Database
DATABASE_URL=""

# Auth (Auth.js v5 — OAuth)
# AUTH_URL: canonical site URL (required for production)
AUTH_URL="http://localhost:3000"
# AUTH_TRUST_HOST: set to true to trust the host header (required for local/proxy setups)
AUTH_TRUST_HOST=true
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
# Google: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://<domain>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Microsoft Entra ID: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Redirect URI: https://<domain>/api/auth/callback/microsoft-entra-id
# TENANT_ID is REQUIRED for Microsoft — Directory (tenant) ID from Azure portal
AUTH_MICROSOFT_ENTRA_ID=""
AUTH_MICROSOFT_ENTRA_SECRET=""
AUTH_MICROSOFT_ENTRA_TENANT_ID=""

# AI
ANTHROPIC_API_KEY=""

# Payments
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
SQUARE_ACCESS_TOKEN=""
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""

# Email
EMAIL_FROM=""
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
# Delay in ms between consecutive invitation emails in a batch. Some SMTP
# providers rate-limit per second — Mailtrap sandbox rejects >1 email/sec
# with "550 5.7.0 Too many emails per second". Set 1200 for Mailtrap
# sandbox, 0 (or leave blank to use the 1200 default) for production hosts
# with higher caps. Only affects bulk create + resend-all; single resends
# are unaffected.
EMAIL_SEND_DELAY_MS=""

# Maps
GOOGLE_MAPS_API_KEY=""

# Frontend URL for password reset / invitation accept links
FRONTEND_URL=""

# ──────────────────────────────────────────────────────────────────────
# CI/CD — GitHub Actions secrets (NOT used locally, add in GitHub repo settings)
# Repo → Settings → Secrets and variables → Actions → New repository secret
# ──────────────────────────────────────────────────────────────────────
# VERCEL_TOKEN       — Vercel personal access token (https://vercel.com/account/tokens)
# VERCEL_ORG_ID      — from .vercel/project.json → "orgId"
# VERCEL_PROJECT_ID  — from .vercel/project.json → "projectId"
# DATABASE_URL       — (same as above, needed for CI build)
# AUTH_SECRET        — (same as above, needed for CI build)
